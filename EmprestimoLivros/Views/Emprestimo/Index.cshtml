@model List<EmprestimoLivros.Models.Livro>

@{
    var total = Model?.Count ?? 0;
    var pausados = Model?.Count(x => (x.Status ?? "") == "Pausado") ?? 0;
    var concluidos = Model?.Count(x => (x.Status ?? "") == "Concluido" || (x.Status ?? "") == "Concluído") ?? 0;
    var andamento = Model?.Count(x => (x.Status ?? "") == "Em andamento") ?? 0;
}

<div class="main">

    <!-- NOME IGUAL SEU PRINT -->
    <h1 class="titulo-winne">📚 Biblioteca da Winne</h1>
    <p class="sub">Seu cantinho fofo e moderno pra organizar livros 📚</p>

    <!-- CONTAGEM -->
    <div class="stats">
        <div class="box">TOTAL <b>@total</b></div>
        <div class="box">EM ANDAMENTO <b>@andamento</b></div>
        <div class="box">PAUSADOS <b>@pausados</b></div>
        <div class="box">CONCLUÍDOS <b>@concluidos</b></div>
    </div>

    <!-- FORM -->
    <form class="add" asp-action="Create" method="post">
        <input name="Nome" placeholder="Nome do livro" required />
        <input name="Autor" placeholder="Autor" required />

        <select name="Status">
            <option>Em andamento</option>
            <option>Pausado</option>
            <option>Concluido</option>
        </select>

        <button class="btn">+ Novo livro</button>
    </form>

    <!-- CARDS -->
    <div class="grid">
        @foreach (var livro in Model)
        {
            <div class="card">
                <h3>@livro.Nome</h3>
                <p>@livro.Autor</p>
                <span class="status">@livro.Status</span>
            </div>
        }
    </div>

</div>


<style>

    /* ===== FUNDO ===== */
    body {
        background: url('/imagens/fundo.jpg') center/cover no-repeat fixed;
        font-family: Segoe UI;
    }

    /* ===== TITULO GRANDE ANIMADO ===== */
    h1 {
        font-size: 70px;
        font-weight: 900;
        letter-spacing: 2px;
        background: linear-gradient( 90deg, #ff2d9a, #ff7ad6, #ffd1ee, #ff2d9a );
        background-size: 300% 300%;
        -webkit-background-clip: text;
        color: transparent;
        animation: tituloMove 4s ease-in-out infinite, tituloFloat 3s ease-in-out infinite;
    }

    @@keyframes tituloMove {
        0%

    {
        background-position: 0% 50%;
    }

    50% {
        background-position: 100% 50%;
    }

    100% {
        background-position: 0% 50%;
    }

    }

    @@keyframes tituloFloat {
        0%,100%

    {
        transform: translateY(0px);
    }

    50% {
        transform: translateY(-8px);
    }

    }

    .sub {
        margin-top: -10px;
        color: white;
    }

    /* ===== CAIXA ===== */
    .main {
        background: rgba(255,255,255,.8);
        padding: 30px;
        border-radius: 30px;
        max-width: 1100px;
        margin: 40px auto;
    }

    /* ===== CONTAGEM ===== */
    .stats {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 10px;
        margin: 20px 0;
    }

    .box {
        background: linear-gradient(135deg,#ff7ad6,#ff2d9a);
        color: white;
        padding: 15px;
        border-radius: 20px;
        font-weight: 900;
    }

    /* ===== FORM ===== */
    .add {
        display: grid;
        grid-template-columns: 1fr 1fr 200px 150px;
        gap: 10px;
        margin-bottom: 20px;
    }

        .add input, .add select {
            padding: 12px;
            border-radius: 15px;
            border: none;
        }

    .btn {
        background: linear-gradient(135deg,#ff2d9a,#ff7ad6);
        color: white;
        border: none;
        border-radius: 15px;
        font-weight: 900;
        cursor: pointer;
    }

    /* ===== CARDS ===== */
    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
        gap: 15px;
    }

    .card {
        background: white;
        padding: 20px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,.2);
        transition: .3s;
    }

        .card:hover {
            transform: translateY(-10px);
        }

    .status {
        background: pink;
        padding: 6px 10px;
        border-radius: 20px;
        font-weight: 900;
    }

</style>  

        .titulo-winne{
    font-size: 90px !important;
    font-weight: 1000 !important;
    letter-spacing: 3px !important;

    background: linear-gradient(
        90deg,
        #ff2d9a,
        #ff7ad6,
        #ffd1ee,
        #ff2d9a
    );
    background-size: 400% 400%;
    -webkit-background-clip: text;
    color: transparent;

    animation: winneMove 5s ease-in-out infinite,
               winneFloat 3s ease-in-out infinite;

    text-shadow: 0 20px 50px rgba(255,45,154,.4);
}

@@keyframes winneMove{
    0%{ background-position:0% 50%; }
    50%{ background-position:100% 50%; }
    100%{ background-position:0% 50%; }
}

@@keyframes winneFloat{
    0%,100%{ transform:translateY(0px); }
    50%{ transform:translateY(-10px); }
}