@{
    ViewData["Title"] = "Adicionar Livro";
}

<div style="max-width:500px;margin:40px auto;padding:20px;background:white;border-radius:20px;box-shadow:0 10px 30px rgba(0,0,0,.1)">
    <h2 style="text-align:center;margin-bottom:20px">📚 Adicionar Livro</h2>

    <form asp-action="Add" method="post">
        @Html.AntiForgeryToken()

        <div style="margin-bottom:12px">
            <input name="titulo" placeholder="Título do livro"
                   style="width:100%;padding:10px;border-radius:10px;border:1px solid #ccc" />
        </div>

        <div style="margin-bottom:12px">
            <input name="autor" placeholder="Autor"
                   style="width:100%;padding:10px;border-radius:10px;border:1px solid #ccc" />
        </div>

        <div style="margin-bottom:16px">
            <select name="status"
                    style="width:100%;padding:10px;border-radius:10px;border:1px solid #ccc">
                <option>Em andamento</option>
                <option>Pausado</option>
                <option>Concluido</option>
            </select>
        </div>

        <button type="submit"
                style="width:100%;padding:12px;border-radius:12px;background:#ff4fa3;color:white;border:0;font-weight:bold">
            Salvar
        </button>
    </form>

    <div style="text-align:center;margin-top:15px">
        <a asp-action="Index">⬅ Voltar</a>
    </div>
</div>